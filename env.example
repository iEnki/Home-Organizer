# ============================================================
# Umzughelfer / Home Organizer — Umgebungsvariablen
# Für die React-App mit externem Supabase (Cloud oder self-hosted)
#
# Kopiere diese Datei als ".env" in das Projektverzeichnis
# (gleiche Ebene wie docker-compose.yml)
#
# Für den kompletten Self-Hosted Stack (inkl. Supabase):
# → .env.full.example verwenden und install.sh ausführen
# ============================================================

# ============================================================
# SUPABASE-VERBINDUNG
# ============================================================

# Öffentliche URL deiner Supabase-Instanz (Cloud oder self-hosted)
REACT_APP_SUPABASE_URL=https://deine-supabase-url

# Anon Key (öffentlich verwendbar, kein Service Role Key!)
REACT_APP_SUPABASE_ANON_KEY=dein-supabase-anon-key

# ============================================================
# APP-EINSTELLUNGEN
# ============================================================

# Redirect-URL nach Passwort-Reset-E-Mail (muss mit deiner App-Domain übereinstimmen)
REACT_APP_PASSWORD_RESET_REDIRECT_URL=https://deine-app-url/update-password

# Externer Port für die App (Nginx hört intern auf 80)
APP_PORT=3000

# Sourcemaps deaktivieren (empfohlen für Produktion)
GENERATE_SOURCEMAP=false

# ============================================================
# WEB PUSH NOTIFICATIONS (VAPID)
# Generieren: npx web-push generate-vapid-keys
#             oder: node scripts/generate-keys.js
# ============================================================

# Public Key wird zur Build-Zeit in die React-App eingebettet
REACT_APP_VAPID_PUBLIC_KEY=dein-vapid-public-key

# ============================================================
# KI-ASSISTENT (optional)
# ============================================================

# OpenAI API Key — wird NICHT als Build-Arg übergeben.
# Der Key wird zur Laufzeit aus dem Supabase-Benutzerprofil geladen.
# Für lokale Entwicklung (npm start) kann er hier eingetragen werden:
# REACT_APP_OPENAI_API_KEY=dein-openai-api-key

# Alternativ: Eigener Ollama-Server (self-hosted LLM)
# Konfiguration erfolgt pro Benutzer in den App-Einstellungen (Profil → KI-Einstellungen)
# Optional: Standard-Ollama-URL vorbelegen (kann in der App überschrieben werden)
# REACT_APP_OLLAMA_URL=http://localhost:11434
